[Unit]
Description=IBP Monitor
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ibp-monitor -config /opt/ibp-geodns-monitor/config/ibpmonitor.json
WorkingDirectory=/opt/ibp-geodns-monitor
User=ibp
Group=ibp
Restart=always
RestartSec=5
Environment=GO_ENV=production

[Install]
WantedBy=multi-user.target